# Copy to .env (gitignored). mise loads it automatically (mise.toml → _.file).
# Non-secret defaults (base url, database url, port) live in mise.toml.

# The full webhook endpoint GitHub posts to, used verbatim. In local dev this is
# your smee.io channel (create one at https://smee.io); `just smee` forwards it to
# the backend's /webhooks/github route. MQ_SMEE_URL is the same channel for `just smee`.
MQ_SERVER__PUBLIC_URL=https://smee.io/REPLACE_ME
MQ_SMEE_URL=https://smee.io/REPLACE_ME

# Static GitHub App credentials — OPTIONAL. Leave unset to use the /setup
# manifest flow (the App's creds are then stored in the DB). When set, these
# take precedence over the DB row.
# MQ_GITHUB__APP_ID=000000
# MQ_GITHUB__APP_SLUG=mergequeue
# MQ_GITHUB__CLIENT_ID=Iv1.0000000000000000
# MQ_GITHUB__CLIENT_SECRET=
# MQ_GITHUB__PRIVATE_KEY_PATH=./mergequeue.private-key.pem
# MQ_GITHUB__WEBHOOK_SECRET=
